# Vendored Python deps for codegen (e.g. wcwidth); not part of the package.
.pyenv/

# Python bytecode caches from the scripts/ codegen.
__pycache__/
*.py[cod]

node_modules/
dist/
*.tsbuildinfo

# Per-developer Claude Code local config (permissions, working dirs).
# The shared .claude/settings.json and .claude/skills/ stay tracked.
.claude/settings.local.json
